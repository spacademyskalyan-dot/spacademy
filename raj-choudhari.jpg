.Banner { background-image: linear-gradient(var(--bgColor-accent-muted), var(--bgColor-accent-muted)); border: var(--borderWidth-thin) solid var(--borderColor-accent-muted); border-radius: var(--borderRadius-medium); color: var(--fgColor-default); padding: var(--base-size-8); grid-template: "visual message actions close" min-content / min-content 1fr minmax(0px, auto) min-content; grid-auto-flow: column; display: grid; position: relative; }

