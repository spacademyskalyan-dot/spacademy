@media (max-width: 430px) {
  .react-contributors-title { display: none; }
}

.react-blame-segment-wrapper { border-bottom: var(--borderWidth-thin) solid var(--borderColor-muted,var(--color-border-muted)); flex-direction: column; width: 100%; display: flex; }

@media (min-width: 768px) {
  .react-blame-segment-wrapper { flex-direction: row; }
