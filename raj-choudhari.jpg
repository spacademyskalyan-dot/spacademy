.avatar-1, .avatar-2, .avatar-small { border-radius: var(--borderRadius-small); }

.avatar-1 { height: var(--base-size-16); width: var(--base-size-16); }

.avatar-2 { height: var(--base-size-20); width: var(--base-size-20); }

.avatar-3 { height: var(--base-size-24); width: var(--base-size-24); }

