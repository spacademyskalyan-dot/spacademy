.avatar { background-color: var(--avatar-bgColor); border-radius: var(--borderRadius-medium); box-shadow: 0 0 0 1px var(--avatar-borderColor); vertical-align: middle; flex-shrink: 0; line-height: 1; display: inline-block; overflow: hidden; }

