.branch-name { font: 12px var(--fontStack-monospace,ui-monospace, SFMono-Regular, SF Mono, Menlo, Consolas, Liberation Mono, monospace); color: var(--fgColor-muted,var(--color-fg-muted)); word-break: break-all; background-color: var(--bgColor-accent-muted,var(--color-accent-subtle)); border-radius: 6px; padding: 2px 6px; display: inline-block; }

