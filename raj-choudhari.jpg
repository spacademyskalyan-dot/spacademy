}

.SelectMenu-list--borderless .SelectMenu-item { border-bottom: 0px; }

.SelectMenu-icon { width: var(--base-size-16); margin-right: var(--base-size-8); flex-shrink: 0; }

.SelectMenu-icon--check { visibility: hidden; transition: transform 0.12s cubic-bezier(0.5, 0.1, 1, 0.5), visibility linear 0.12s; transform: scale(0); }

.SelectMenu-tabs { box-shadow: inset 0 -1px 0 var(--borderColor-muted,var(--color-border-muted)); flex-shrink: 0; display: flex; overflow: auto hidden; }

