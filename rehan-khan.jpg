.avatar-parent-child { position: relative; }

.avatar-child { background-color: var(--bgColor-default,var(--color-canvas-default)); box-shadow: var(--avatar-shadow,var(--color-avatar-child-shadow)); border-radius: 4px; position: absolute; bottom: -9%; right: -15%; }

