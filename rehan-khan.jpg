.markdown-body span.align-right span img { text-align: right; margin: 0px; }

.markdown-body span.float-left { float: left; margin-right: 13px; display: block; overflow: hidden; }

.markdown-body span.float-left span { margin: 13px 0px 0px; }

.markdown-body span.float-right { float: right; margin-left: 13px; display: block; overflow: hidden; }

.markdown-body span.float-right > span { text-align: right; margin: 13px auto 0px; display: block; overflow: hidden; }

.markdown-body code, .markdown-body tt { white-space: break-spaces; background-color: var(--bgColor-neutral-muted,var(--color-neutral-muted)); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em; font-size: 85%; }

.markdown-body code br, .markdown-body tt br { display: none; }

.markdown-body del code { text-decoration: inherit; }

.markdown-body samp { font-size: 85%; }

.markdown-body pre { overflow-wrap: normal; }

.markdown-body pre code { font-size: 100%; }

.markdown-body pre > code { word-break: normal; white-space: pre; background: 0px 0px; border: 0px; margin: 0px; padding: 0px; }

.markdown-body .highlight { margin-bottom: var(--base-size-16); }

.markdown-body .highlight pre { word-break: normal; margin-bottom: 0px; }

.markdown-body .highlight pre, .markdown-body pre { padding: var(--base-size-16); color: var(--fgColor-default,var(--color-fg-default)); background-color: var(--bgColor-muted,var(--color-canvas-subtle)); border-radius: 6px; font-size: 85%; line-height: 1.45; overflow: auto; }

.markdown-body pre code, .markdown-body pre tt { line-height: inherit; overflow-wrap: normal; background-color: rgba(0, 0, 0, 0); border: 0px; margin: 0px; padding: 0px; display: inline; overflow: visible; }

.markdown-body .csv-data td, .markdown-body .csv-data th { text-align: left; white-space: nowrap; padding: 5px; font-size: 12px; line-height: 1; overflow: hidden; }

.markdown-body .csv-data .blob-num { padding: 10px var(--base-size-8) 9px; text-align: right; background: var(--bgColor-default,var(--color-canvas-default)); border: 0px; }

.markdown-body .csv-data tr { border-top: 0px; }

.markdown-body .csv-data th { font-weight: var(--base-text-weight-semibold,600); background: var(--bgColor-muted,var(--color-canvas-subtle)); border-top: 0px; }

.markdown-body [data-footnote-ref]::before { content: "["; }

.markdown-body [data-footnote-ref]::after { content: "]"; }

.markdown-body .footnotes { color: var(--fgColor-muted,var(--color-fg-muted)); border-top: 1px solid var(--borderColor-default,var(--color-border-default)); font-size: 12px; }

.markdown-body .footnotes ol { padding-left: var(--base-size-16); }

