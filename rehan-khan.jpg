}

@media (min-width: 768px) {
  .blob-license-banner-outer { flex-direction: row; }
  .find-in-file-popover-stickied { top: 98px; right: var(--base-size-8); z-index: 11; background: var(--bgColor-default,var(--color-canvas-default)); border-radius: var(--borderRadius-large); box-shadow: var(--shadow-floating-large,var(--color-shadow-large)); border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; position: absolute; }
  .find-in-file-popover-not-stickied { top: 52px; right: var(--base-size-8); z-index: 11; background: var(--bgColor-default,var(--color-canvas-default)); border-radius: var(--borderRadius-large); box-shadow: var(--shadow-floating-large,var(--color-shadow-large)); border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; position: absolute; }
}

.react-blob-textarea { }

.react-blob-textarea::-webkit-scrollbar { display: none; }

.react-blob-textarea.select-contrast::selection { color: initial; }

.react-blob-scroll-marks { }

