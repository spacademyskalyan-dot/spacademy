.audit-type .octicon { margin-right: var(--base-size-4); font-weight: var(--base-text-weight-normal); vertical-align: bottom; }

.audit-type .repo { color: var(--fgColor-severe); }

.audit-type .team { color: var(--fgColor-success); }

.audit-type .user { color: var(--fgColor-done); }

