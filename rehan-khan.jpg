.SelectMenu-tab { padding: var(--base-size-8) var(--base-size-16); font-size: 12px; font-weight: var(--base-text-weight-medium,500); color: var(--fgColor-muted,var(--color-fg-muted)); text-align: center; box-shadow: inset 0 -1px 0 var(--borderColor-muted,var(--color-border-muted)); background-color: rgba(0, 0, 0, 0); border: 0px; flex: 1 1 0%; }

@media (min-width: 544px) {
