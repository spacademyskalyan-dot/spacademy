.markdown-body .footnotes li { position: relative; }

.markdown-body .footnotes li:target::before { top: calc(var(--base-size-8)*-1); right: calc(var(--base-size-8)*-1); bottom: calc(var(--base-size-8)*-1); left: calc(var(--base-size-24)*-1); pointer-events: none; content: ""; border: 2px solid var(--borderColor-accent-emphasis,var(--color-accent-emphasis)); border-radius: 6px; position: absolute; }

