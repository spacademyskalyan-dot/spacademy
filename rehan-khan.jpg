.Button--danger:hover:not(:disabled, .Button--inactive) { background-color: var(--button-danger-bgColor-hover); border-color: var(--button-danger-borderColor-hover); box-shadow: var(--shadow-resting-small); color: var(--button-danger-fgColor-hover); fill: var(--button-danger-fgColor-hover); }

