.branches-tag-list { margin-right: var(--base-size-8); vertical-align: middle; margin-left: 2px; list-style: none; display: inline; }

.branches-tag-list .more-commit-details, .branches-tag-list.open .hidden-text-expander { display: none; }

.branches-tag-list.open .more-commit-details { display: inline-block; }

.branches-tag-list li { padding-left: var(--base-size-4); display: inline-block; }

.branches-tag-list li:first-child { font-weight: var(--base-text-weight-semibold); color: var(--fgColor-default,var(--color-fg-default)); padding-left: 0px; }

.branches-tag-list li.loading { font-weight: var(--base-text-weight-normal); color: var(--fgColor-muted,var(--color-fg-muted)); }

.branches-tag-list li.abbrev-tags { cursor: pointer; }

.branches-tag-list li a { color: inherit; }

