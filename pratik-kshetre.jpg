.team-member-list .invite-icon { width: 28px; color: var(--fgColor-muted); }

.menu-item-danger, .menu-item-danger.selected { color: var(--fgColor-danger); }

.menu-item-danger:hover, .menu-item-danger[aria-selected="true"], .menu-item-danger.navigation-focus, .menu-item-danger.selected:hover, .menu-item-danger.selected[aria-selected="true"], .menu-item-danger.selected.navigation-focus { color: var(--fgColor-onEmphasis); background: var(--bgColor-danger-emphasis); }

