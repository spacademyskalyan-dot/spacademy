.Button--invisible:disabled, .Button--invisible[aria-disabled="true"] { background-color: var(--button-invisible-bgColor-disabled); border-color: var(--button-invisible-borderColor-disabled); color: var(--button-invisible-fgColor-disabled); fill: var(--button-invisible-fgColor-disabled); }

.Button--invisible.Button--invisible-noVisuals .Button-label { color: var(--button-invisible-fgColor-rest); }

