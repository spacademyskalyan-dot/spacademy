.codespaces-policy-allowed-values-dropdown { --allowed-values-dropdown-mt: 8px; --allowed-values-dropdown-mr: 4px; --allowed-values-dropdown-py: 12px; --allowed-values-dropdown-px: 8px; --allowed-values-dropdown-width: 280px; }

.codespaces-policy-allowed-values-base-images-input { --allowed-values-input-dropdown-mt: 8px; --allowed-values-input-dropdown-mr: 4px; --allowed-values-input-dropdown-py: 12px; --allowed-values-input-dropdown-px: 8px; --allowed-values-input-dropdown-width: 600px; }

.codespaces-policy-repository-dialog .css-truncate-target { white-space: normal; max-width: none; text-overflow: unset; overflow-wrap: break-word; line-height: var(--text-body-lineHeight-medium); overflow: visible; }

@media (max-width: 768px) {
