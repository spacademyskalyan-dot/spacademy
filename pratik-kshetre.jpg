.mini-repo-list-item { padding: var(--base-size-4) var(--base-size-64) var(--base-size-4) var(--base-size-32); font-size: var(--text-body-size-medium); border-top: var(--borderWidth-thin) solid var(--borderColor-default); display: block; position: relative; }

.mini-repo-list-item:hover { text-decoration: none; }

