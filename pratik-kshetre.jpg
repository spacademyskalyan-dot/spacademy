  label { font-weight: var(--base-text-weight-semibold,600); }
  ::placeholder { color: var(--fgColor-muted,var(--color-fg-subtle)); opacity: 1; }
  hr, .rule { border-top: 0px; border-right: 0px; border-left: 0px; border-image: initial; border-bottom: 1px solid var(--borderColor-muted,var(--color-border-muted)); background: 0px 0px; height: 0px; margin: 15px 0px; overflow: hidden; }
  hr::before, .rule::before { content: ""; display: table; }
  hr::after, .rule::after { clear: both; content: ""; display: table; }
