  .codespaces-policy-allowed-values-base-images-input { --allowed-values-input-dropdown-mt: 4px; --allowed-values-input-dropdown-mr: 2px; --allowed-values-input-dropdown-py: 8px; --allowed-values-input-dropdown-px: 6px; --allowed-values-input-dropdown-width: min(500px, 90vw); --allowed-values-input-translate-x: 20%; transform: translateX(var(--allowed-values-input-translate-x)); }
