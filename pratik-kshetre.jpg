.prereceive-feedback { padding: var(--base-size-16); margin-bottom: var(--base-size-16); border-top-color: ; border-top-style: ; border-top-width: ; border-right-color: ; border-right-style: ; border-right-width: ; border-bottom-color: ; border-bottom-style: ; border-bottom-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-left: var(--borderRadius-medium) solid #caa21a; border-radius: var(--borderRadius-medium); }

.prereceive-feedback-heading { margin-top: 0px; margin-bottom: var(--base-size-8); color: var(--fgColor-attention); }

.revert-error { padding: var(--base-size-16); margin-bottom: var(--base-size-16); border-top-color: ; border-top-style: ; border-top-width: ; border-right-color: ; border-right-style: ; border-right-width: ; border-bottom-color: ; border-bottom-style: ; border-bottom-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-left: var(--borderRadius-medium) solid #a32d35; border-radius: var(--borderRadius-medium); }

.revert-error-heading { margin-top: 0px; margin-bottom: var(--base-size-8); color: var(--fgColor-danger); }

.repository-item-checkbox:checked + .repository-item-name { background-color: var(--bgColor-accent-muted); }

.custom-role-icon { background-color: var(--bgColor-muted); }

.security-center-filter-wrap { grid-template-columns: minmax(0px, 1fr); gap: 8px; display: grid; }

@media (min-width: 1012px) {
  .security-center-filter-wrap { grid-template-columns: minmax(0px, 1fr) max-content; }
}

.recent-user-key-access { color: rgb(30, 126, 52); }

.access-token { border-bottom: var(--borderWidth-thin) solid var(--borderColor-muted); }

.access-token:last-child { border: 0px; }

.access-token .last-used { margin-right: var(--base-size-8); }

.access-token.new-token { background-color: rgba(108, 198, 68, 0.1); }

