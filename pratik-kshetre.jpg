  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}

.Overlay-form { flex-grow: 1; overflow: auto; }

.Overlay-form, .Overlay-header { flex-direction: column; display: flex; }

.Overlay-header { color: var(--fgColor-default); z-index: 1; }

