.theme-name { margin-right: var(--base-size-8); margin-left: var(--base-size-8); font-size: var(--text-title-size-medium); vertical-align: middle; line-height: 1; display: inline-block; }

.pinned-items-spinner { position: relative; top: 2px; left: 6px; }

