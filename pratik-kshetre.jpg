.TransactionalMessageBanner-module__squareBanner__Pw6Pf { border-radius: 0px; }

.BannerNudgeCard-module__IconWrapper__cXfHh { width: 32px; height: 32px; margin-right: var(--base-size-12); background-color: var(--bgColor-done-muted); color: var(--fgColor-done); border-radius: 50%; flex-shrink: 0; justify-content: center; align-self: flex-start; align-items: center; display: flex; position: relative; }

.BannerNudgeCard-module__IconWrapper__cXfHh::before { --border-match-theme-bg: var(--bgColor-default,var(--color-canvas-default)); content: ""; top: 0px; right: calc(-1 * var(--base-size-2)); border: var(--borderWidth-thick) solid var(--border-match-theme-bg); background-color: var(--bgColor-done-emphasis); z-index: 1; border-radius: 50%; width: 8px; height: 8px; position: absolute; }

.styles-module__appHeader__YzYWk { color: var(--fgColor-default); background: var(--bgColor-inset); box-shadow: inset 0 calc(var(--borderWidth-thin,1px) * -1) var(--borderColor-default); }

.styles-module__left__Fylw7 { padding-right: var(--base-size-8); }

.styles-module__right__mlBQg { padding-left: var(--base-size-8); }

.styles-module__withLocalNavigation__rjTJ_ { padding-bottom: var(--base-size-4); }

.styles-module__appHeaderButton__axedQ { border: solid var(--borderWidth-thin) var(--control-borderColor-rest); }

.styles-module__itemDivider__nunbs { width: var(--borderWidth-thin); background: var(--control-borderColor-rest); height: var(--base-size-20); margin-inline: var(--base-size-4); }

.styles-module__center__R3QRv { flex: 1 1 0%; min-width: 0px; padding-inline: 0px; }

.styles-module__hideTopNav__zle2W { display: none; }

@media (max-width: 1024px) {
