.graphs .selection .overlay { }

.graphs .selection .selection { fill: var(--fgColor-neutral); fill-opacity: 0.1; stroke: var(--fgColor-default); stroke-dasharray: 3, 3; stroke-opacity: 0.4; stroke-width: 1px; shape-rendering: crispedges; }

