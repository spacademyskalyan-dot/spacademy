:is(.Popover-message--top-left, .Popover-message--bottom-left)::after { left: var(--base-size-24); margin-left: 1px; }

:is(.Popover-message--right, .Popover-message--right-top, .Popover-message--right-bottom, .Popover-message--left, .Popover-message--left-top, .Popover-message--left-bottom)::after, :is(.Popover-message--right, .Popover-message--right-top, .Popover-message--right-bottom, .Popover-message--left, .Popover-message--left-top, .Popover-message--left-bottom)::before { border-bottom-color: rgba(0, 0, 0, 0); margin-left: 0px; top: 50%; left: auto; }

