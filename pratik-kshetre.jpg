.showcase-page-pattern { z-index: -1; height: 100px; margin-top: calc(var(--base-size-24)*-1); margin-bottom: -70px; position: relative; }

.showcase-page-pattern::after { content: ""; background-image: linear-gradient(rgba(255, 255, 255, 0.85), rgb(255, 255, 255)); display: block; position: absolute; inset: 0px; }

.showcase-page-repo-list { border-top: var(--borderWidth-thin) solid var(--borderColor-muted); }

.slash-command-menu-item .command-description { color: var(--fgColor-muted); }

