.Overlay.Overlay--width-medium { width: min(320px, -2rem + 100vw); }

.Overlay.Overlay--width-large { width: min(480px, -2rem + 100vw); }

.Overlay.Overlay--width-xlarge { width: min(640px, -2rem + 100vw); }

.Overlay.Overlay--width-xxlarge { width: min(960px, -2rem + 100vw); }

.Overlay:modal { position: fixed; }

