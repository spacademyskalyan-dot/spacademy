.filter-item { padding: var(--base-size-8) var(--base-size-16); margin-bottom: var(--base-size-4); color: var(--fgColor-muted,var(--color-fg-muted)); text-overflow: ellipsis; white-space: nowrap; cursor: pointer; border-radius: 6px; font-size: 14px; text-decoration: none; display: block; position: relative; overflow: hidden; }

