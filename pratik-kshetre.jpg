:is(.Button--invisible .Button-visual) .Counter { color: var(--fgColor-default); }

.Button--link { color: var(--fgColor-link); fill: var(--fgColor-link); font-size: inherit; height: unset; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; min-width: fit-content; padding: 0px; display: inline-block; }

.Button--link:hover:not(:disabled, .Button--inactive) { text-decoration: underline; }

.Button--link:focus, .Button--link:focus-visible { outline-offset: 2px; }

