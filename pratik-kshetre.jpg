.Button--primary:disabled, .Button--primary[aria-disabled="true"] { background-color: var(--button-primary-bgColor-disabled); border-color: var(--button-primary-borderColor-disabled); color: var(--button-primary-fgColor-disabled); fill: var(--button-primary-fgColor-disabled); }

.Button--primary .Counter { background-color: var(--buttonCounter-primary-bgColor-rest); color: inherit; }

.Button--secondary { background-color: var(--button-default-bgColor-rest); border-color: var(--button-default-borderColor-rest); box-shadow: var(--button-default-shadow-resting),var(--button-default-shadow-inset); color: var(--button-default-fgColor-rest); fill: var(--fgColor-muted); }

