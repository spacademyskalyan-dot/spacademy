.pinned-item-checkbox:disabled + .pinned-item-name { color: var(--fgColor-muted); }

.pinned-item-checkbox:disabled + .pinned-item-name:hover { cursor: default; }

.pinned-gist-blob-num { cursor: default; min-width: 36px; }

