.pagination a:hover, .pagination a:focus, .pagination span:hover, .pagination span:focus, .pagination em:hover, .pagination em:focus { border-color: var(--borderColor-default,var(--color-border-default)); text-decoration: none; transition-duration: 0.1s; }

