.Overlay.Overlay--placement-right { border-top-right-radius: 0px; border-bottom-right-radius: 0px; animation-name: Overlay--motion-slideInLeft; inset: 0px 0px 0px auto; }

.Overlay.Overlay--height-xsmall { height: min(192px, -2rem + 100vh); }

.Overlay.Overlay--height-small { height: min(256px, -2rem + 100vh); }

.Overlay.Overlay--height-medium { height: min(320px, -2rem + 100vh); }

.Overlay.Overlay--height-large { height: min(432px, -2rem + 100vh); }

.Overlay.Overlay--height-xlarge { height: min(600px, -2rem + 100vh); }

