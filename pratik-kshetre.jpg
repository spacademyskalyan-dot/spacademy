@media screen and (prefers-reduced-motion: no-preference) {
  .Overlay.Overlay--motion-scaleFade, .Overlay.Overlay--placement-left, .Overlay.Overlay--placement-right { animation: 0.2s cubic-bezier(0.33, 1, 0.68, 1) 0s 1 normal none running Overlay--motion-scaleFade; }
}

