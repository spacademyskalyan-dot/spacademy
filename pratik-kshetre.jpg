  [popover]:not(.\:popover-open) { display: none; }
}

.Overlay { background-color: var(--overlay-bgColor); border-radius: var(--borderRadius-large); box-shadow: var(--shadow-floating-small); color: var(--fgColor-default); max-height: min(100vh - 2rem,var(--overlay-height)); opacity: 1; white-space: normal; min-width: 192px; width: min(var(--overlay-width),100vw - 2rem); border: 0px; flex-direction: column; margin: auto; padding: 0px; display: flex; position: static; inset: 0px; }

